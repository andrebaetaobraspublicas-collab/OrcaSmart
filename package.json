{
    "name": "orcasmart2-saas",
    "version": "2.0.0-alpha.1",
    "description": "OrcaSmart2 SaaS - backend Node.js consolidado",
    "main": "server.js",
    "scripts": {
        "start": "node server-bootstrap.js",
        "dev": "node server-bootstrap.js",
        "audit-db": "python database/auditar_integridade.py",
        "init-db": "python database/init.py",
        "start:python": "python server.py",
        "test:bdi": "node tests/bdiRules.test.js && node tests/bdiRoutesScope.test.js",
        "test:riscos": "node tests/riscosEngine.test.js && node tests/riscosBdiIntegration.test.js",
        "init-db:node": "node database/init.js",
        "build:shared-catalog": "node scripts/buildSharedCatalog.js --force",
        "build:tenant-template": "node scripts/buildTenantTemplate.js --force",
        "phase4:audit-model": "node scripts/phase4DataModelAudit.js",
        "phase4:generate-mysql-schema": "node scripts/phase4GenerateMysqlSchema.js",
        "phase4:validate-mysql-schema": "node scripts/phase4ValidateMysqlSchema.js",
        "phase4:mysql-readiness": "node scripts/phase4MysqlReadiness.js",
        "phase4:migrate-master-mysql": "node scripts/phase4MigrateMasterToMysql.js",
        "phase4:validate-master-mysql": "node scripts/phase4ValidateMasterMysql.js",
        "phase4:migrate-catalog-mysql": "node scripts/phase4MigrateCatalogToMysql.js",
        "phase4:validate-catalog-mysql": "node scripts/phase4ValidateCatalogMysql.js",
        "phase4:migrate-tenant-mysql": "node scripts/phase4MigrateTenantToMysql.js",
        "phase4:validate-tenant-mysql": "node scripts/phase4ValidateTenantMysql.js",
        "phase4:cutover-readiness": "node scripts/phase4CutoverReadiness.js",
        "phase4:rehearsal": "node scripts/phase4MigrationRehearsal.js",
        "phase4:execute-mysql": "node scripts/phase4ExecuteMysqlMigration.js"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "mysql2": "^3.11.5",
        "pdf-parse": "^1.1.1",
        "sqlite3": "^5.1.7",
        "stripe": "^17.5.0"
    },
    "devDependencies": {
        "nodemon": "^3.0.1"
    },
    "keywords": [
        "orcamento",
        "obras",
        "engenharia",
        "custos"
    ],
    "author": "",
    "license": "ISC"
}
